{
  "name": "tabbytab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:watch": "concurrently \"npm run typecheck -- --watch\" \"vite\"",
    "build": "npm run typecheck && vite build",
    "build:prod": "NODE_ENV=production npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "clean": "rimraf dist",
    "check-all": "npm run typecheck && npm run lint && npm run format:check",
    "test": "node tests/smoke.test.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.81.1",
    "preact": "^10.19.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "@eslint/js": "^9.28.0",
    "@preact/preset-vite": "^2.7.0",
    "@types/chrome": "^0.0.260",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "concurrently": "^9.1.2",
    "esbuild": "^0.19.12",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.10",
    "typescript": "^5.2.2",
    "vite": "^5.0.10"
  }
}
